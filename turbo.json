{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!-node_modules"
      ]
    },
    "admin-dashboard#build": {
      "dependsOn": [
        "^build",
        "admin-api#build",
        "api#build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!-node_modules"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": [
        "^start"
      ],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^build"
      ]
    },
    "format": {}
  }
}